{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "readonly/*"
  ],
  "scripts": {
    "action": "sh up.sh && bun run test",
    "build": "bash -c \"turbo build --output-logs=errors-only 2> >(grep -vE 'WARNING|Could not resolve workspaces|missing field|Turborepo will still function' >&2)\"",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "dev": "turbo dev",
    "fix": "bun run build && lintmax fix",
    "postinstall": "sherif",
    "prepare": "bunx simple-git-hooks",
    "test": "bash -c \"turbo test --output-logs=errors-only 2> >(grep -vE 'WARNING|Could not resolve workspaces|missing field|Turborepo will still function' >&2)\""
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "latest",
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/typography": "latest",
    "@testing-library/react": "latest",
    "@turbo/gen": "latest",
    "lintmax": "latest",
    "playwright-core": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "unrun": "latest"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "esbuild",
    "lintmax",
    "msw",
    "sharp",
    "simple-git-hooks"
  ]
}
